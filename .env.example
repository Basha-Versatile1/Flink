# Copy to .env and fill in. All are optional in v1 (sensible fallbacks exist).
# Astro exposes vars prefixed with PUBLIC_ to client-side code.

# Lead form POST target. Leave blank to use the built-in no-op stub (logs + fake success).
PUBLIC_LEAD_ENDPOINT=

# App store links (fallback to "#" placeholders until apps are published).
PUBLIC_PLAY_URL=
PUBLIC_APPSTORE_URL=
