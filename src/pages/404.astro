---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import Icon from "@/components/Icon.astro";
import { buildMeta } from "@/lib/seo";

const meta = buildMeta({
  title: "Page not found",
  description: "The page you were looking for could not be found.",
  path: "/404",
});
---

<Layout meta={meta}>
  <Section tone="transparent" class="text-center">
    <div class="mx-auto max-w-md">
      <p class="text-6xl font-bold text-primary-deep">404</p>
      <h1 class="mt-4 text-3xl">This page took the day off</h1>
      <p class="mt-3 text-ink-soft">
        We couldn&apos;t find what you were looking for. Let&apos;s get you back to a spotless start.
      </p>
      <div class="mt-7 flex justify-center">
        <Button href="/" size="lg">
          <Icon name="arrow-right" size={18} class="rotate-180" />
          Back to home
        </Button>
      </div>
    </div>
  </Section>
</Layout>
