---
import Layout from "@/layouts/Layout.astro";
import LegalPage from "@/components/LegalPage.astro";
import { buildMeta } from "@/lib/seo";
import { BRAND_NAME } from "@/lib/config";

const meta = buildMeta({
  title: "Terms & Conditions",
  description: `The terms governing your use of ${BRAND_NAME} services.`,
  path: "/legal/terms",
});
---

<Layout meta={meta}>
  <LegalPage title="Terms & Conditions" intro="The agreement between you and Flink when you use our services.">
