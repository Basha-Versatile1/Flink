---
import Layout from "@/layouts/Layout.astro";
import LegalPage from "@/components/LegalPage.astro";
import { buildMeta } from "@/lib/seo";
import { BRAND_NAME } from "@/lib/config";

const meta = buildMeta({
  title: "Refund & Cancellation Policy",
  description: `How cancellations and refunds work with ${BRAND_NAME}.`,
  path: "/legal/refund",
});
---

<Layout meta={meta}>
  <LegalPage title="Refund & Cancellation Policy" intro="How cancellations, rescheduling, and refunds are handled.">
    {/* TODO: replace all placeholder sections with finalised refund policy. */}
