---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import { FAQS } from "@/data/faqs";

/**
 * FAQ accordion using native <details>/<summary> — fully accessible and
 * keyboard-operable with ZERO JavaScript. The [open] arrow flip is pure CSS.
 */
---

<Section id="faq" tone="dark">
  <SectionHeading
    eyebrow="FAQ"
    title="Questions,"
    accent="answered"
    intro="Everything you might want to know before your first Flink booking."
    onDark
  />

  <div class="mx-auto mt-12 max-w-3xl divide-y divide-hairline rounded-card bg-white shadow-soft ring-1 ring-hairline/70">
    {
      FAQS.map((item, i) => (
        <details class="faq-item group" open={i === 0}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 text-base font-semibold text-ink transition-colors hover:text-primary-deep sm:px-6">
            <span>{item.question}</span>
            <Icon name="plus" size={20} class="faq-plus shrink-0 text-primary" />
            <Icon name="minus" size={20} class="faq-minus hidden shrink-0 text-primary" />
          </summary>
          <div class="px-5 pb-5 text-ink-soft sm:px-6">
            <p class="leading-relaxed">{item.answer}</p>
          </div>
        </details>
      ))
    }
  </div>
</Section>

<style>
  /* Swap +/- icons based on open state — pure CSS, no JS. */
  details[open] .faq-plus {
    display: none;
  }
  details[open] .faq-minus {
    display: block;
  }
  summary::-webkit-details-marker {
    display: none;
  }
</style>
