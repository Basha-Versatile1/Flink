---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import Button from "@/components/ui/Button.astro";
import { SERVICES } from "@/data/services";
import { CITY } from "@/data/localities";

// Gradient icon tiles (multi-hue, with a coloured glow). Literal strings so
// Tailwind's JIT keeps every class.
const TILES = [
  "bg-primary",
  "bg-primary",
  "bg-primary",
  "bg-primary",
  "bg-primary",
  "bg-primary",
];
---

<Section id="services" tone="cyan" class="relative overflow-hidden">
  <!-- Soft cyan glow behind the heading -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-0 h-72 w-[44rem] max-w-full -translate-x-1/2 rounded-full bg-primary/10 blur-[100px]"
  >
  </div>

  <div class="relative">
    <SectionHeading
      eyebrow="What we clean"
      title="Cleaning services for"
      accent="every corner of your home"
      intro="Pick a single task or reset the whole place. Every visit is handled by a trained Flink professional."
    />

    <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        SERVICES.map((service, i) => (
          <Reveal as="li" delay={(i % 3) * 80}>
            <a
              href={`/${service.slug}/${CITY.slug}`}
              class="group block h-full focus-visible:outline-none"
            >
              <article class="relative isolate flex h-full flex-col overflow-hidden rounded-card border border-hairline bg-white shadow-soft transition-all duration-200 group-hover:border-primary/40 group-hover:shadow-lift">
                {service.image ? (
                  <div class="relative aspect-[16/10] w-full overflow-hidden bg-surface-cyan">
                    <img
                      src={service.image}
                      alt={`${service.name} by a Flink professional`}
                      width="1000"
                      height="625"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.04]"
                      loading="lazy"
                    />
                    <span aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/45 to-transparent"></span>
                  </div>
                ) : (
                  <div class="flex aspect-[16/10] w-full items-center justify-center bg-surface-cyan">
                    <span
                      class={`inline-flex h-14 w-14 items-center justify-center rounded-2xl text-white ${TILES[i % TILES.length]}`}
                    >
                      <Icon name={service.icon as any} size={26} />
                    </span>
                  </div>
                )}
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="text-lg font-semibold text-ink">{service.name}</h3>
                  <p class="mt-2 flex-1 text-sm text-ink-soft">{service.tagline}</p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary-deep">
                    Book in {CITY.name}
                    <Icon
                      name="arrow-right"
                      size={16}
                      class="transition-transform group-hover:translate-x-0.5"
                    />
                  </span>
                </div>
              </article>
            </a>
          </Reveal>
        ))
      }
    </ul>

    <div class="mt-10 text-center">
      <Button href="#download" variant="secondary" size="lg">
        View all services in the app
        <Icon name="arrow-right" size={18} />
      </Button>
    </div>
  </div>
</Section>
