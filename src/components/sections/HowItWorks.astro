---
import Section from "@/components/ui/Section.astro";
import Reveal from "@/components/ui/Reveal.astro";
import Icon from "@/components/Icon.astro";
import HowItWorksPhone from "@/components/HowItWorksPhone.astro";
import { HOW_IT_WORKS } from "@/data/site";
import type { IconName } from "@/lib/icons";

/**
 * `compact` renders all three steps as a single-screen animated timeline
 * (used on service pages). Default is the desktop sticky scroll-story with
 * app screens (used on the homepage).
 */
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<Section id="how-it-works" tone="white" class="relative overflow-hidden">
  <!-- Soft top-to-violet wash -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-white via-white to-violet-50/70"
  >
  </div>

  <div class="relative">
    <!-- Heading -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="mb-4 inline-flex items-center rounded-pill bg-violet-100 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-violet-700">
        How it works
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        Simple steps to a <span class="text-violet-600">cleaner home</span>
      </h2>
      <p class="mt-4 text-lg text-ink-soft">
        No calls, no haggling — book a trained Flink professional in under a minute.
      </p>
    </div>

    {
      compact ? (
        /* COMPACT: single-screen animated timeline — connector draws on scroll-in. */
        <div class="mt-16" data-hiw-timeline>
          <ol class="relative grid gap-12 sm:grid-cols-3 sm:gap-6">
            {/* Connector track behind the nodes (desktop) */}
            <div aria-hidden="true" class="absolute left-[16%] right-[16%] top-7 hidden h-[3px] rounded-full bg-violet-100 sm:block">
              <div class="hiw-line h-full origin-left rounded-full bg-gradient-to-r from-violet-500 via-fuchsia-500 to-primary" />
              <span class="hiw-spark absolute top-1/2 h-3 w-3 -translate-y-1/2 rounded-full bg-white shadow-[0_0_14px_5px_rgba(124,58,237,0.65)]" />
            </div>

            {HOW_IT_WORKS.map((step, i) => (
              <li class="relative flex flex-col items-center text-center">
                <span
                  class="hiw-node relative z-10 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-violet-600 to-violet-400 text-white shadow-[0_14px_30px_-8px_rgba(124,58,237,0.6),inset_0_1px_0_0_rgba(255,255,255,0.45)]"
                  style={`transition-delay:${i * 160}ms`}
                >
                  <Icon name={step.icon as IconName} size={24} />
                  <span class="absolute -right-1.5 -top-1.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-white text-[10px] font-bold text-violet-700 ring-1 ring-violet-200">
                    {step.step}
                  </span>
                </span>
                <h3 class="mt-5 text-lg font-semibold text-ink">{step.title}</h3>
                <p class="mx-auto mt-1.5 max-w-xs text-sm text-ink-soft">{step.body}</p>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <>
          {/* MOBILE / tablet: simple stacked steps (no scroll-jacking) */}
          <ol class="mt-14 space-y-14 lg:hidden">
            {HOW_IT_WORKS.map((step, i) => (
              <Reveal as="li" delay={i * 80} class="flex flex-col items-center text-center">
                <HowItWorksPhone step={i} class="!w-[210px]" />
                <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-violet-600">Step {step.step}</p>
                <h3 class="mt-1 text-lg font-semibold text-ink">{step.title}</h3>
                <p class="mx-auto mt-1.5 max-w-xs text-sm text-ink-soft">{step.body}</p>
              </Reveal>
            ))}
          </ol>

          {/* DESKTOP: sticky scroll-story — phone advances step-by-step as you scroll */}
          <div class="mt-10 hidden lg:grid lg:grid-cols-2 lg:gap-16" data-howitworks>
            <ol class="py-[18vh]">
              {HOW_IT_WORKS.map((step, i) => (
                <li data-hiw-step={i} class="hiw-step flex min-h-[56vh] flex-col justify-center">
                  <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-violet-600 text-base font-bold text-white shadow-[0_8px_20px_-6px_rgba(124,58,237,0.6)]">
                    {step.step}
                  </span>
                  <p class="mt-5 text-xs font-semibold uppercase tracking-wide text-violet-600">Step {step.step}</p>
                  <h3 class="mt-1 text-2xl font-bold text-ink">{step.title}</h3>
                  <p class="mt-3 max-w-md text-base text-ink-soft">{step.body}</p>
                </li>
              ))}
            </ol>

            <div class="relative">
              <div class="sticky top-0 flex h-screen flex-col items-center justify-center">
                <div class="relative h-[440px] w-[214px]">
                  {HOW_IT_WORKS.map((_, i) => (
                    <div data-hiw-screen={i} class="hiw-screen absolute inset-0 flex items-center justify-center">
                      <HowItWorksPhone step={i} class="!w-[210px]" />
                    </div>
                  ))}
                </div>
                <div class="mt-8 flex items-center gap-2.5" aria-hidden="true">
                  {HOW_IT_WORKS.map((_, i) => (
                    <span data-hiw-dot={i} class="hiw-dot h-2 w-2 rounded-full bg-violet-200 transition-all duration-300" />
                  ))}
                </div>
              </div>
            </div>
          </div>
        </>
      )
    }
  </div>
</Section>

<style>
  /* Scroll-story active states (desktop). JS toggles .is-active. */
  .hiw-step {
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }
  .hiw-step.is-active {
    opacity: 1;
  }

  .hiw-screen {
    opacity: 0;
    transform: scale(0.96) translateY(10px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .hiw-screen.is-active {
    opacity: 1;
    transform: none;
  }

  .hiw-dot.is-active {
    width: 1.5rem;
    background-color: rgb(124 58 237); /* violet-600 */
  }

  /* ---- Compact timeline (service pages): draws on scroll-in ---- */
  .hiw-line {
    transform: scaleX(0);
    transition: transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1) 0.15s;
  }
  [data-hiw-timeline].is-inview .hiw-line {
    transform: scaleX(1);
  }
  .hiw-node {
    opacity: 0;
    transform: translateY(14px) scale(0.8);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  [data-hiw-timeline].is-inview .hiw-node {
    opacity: 1;
    transform: none;
  }
  .hiw-spark {
    left: 0;
    opacity: 0;
  }
  [data-hiw-timeline].is-inview .hiw-spark {
    animation: sparkTravel 1.25s ease 0.15s forwards;
  }
  @keyframes sparkTravel {
    0% {
      left: 0;
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      left: 100%;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hiw-step,
    .hiw-screen,
    .hiw-node {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hiw-line {
      transform: scaleX(1);
      transition: none;
    }
    .hiw-spark {
      display: none;
    }
  }
</style>

<script>
  function initHowItWorks() {
    const root = document.querySelector<HTMLElement>("[data-howitworks]");
    if (!root) return;

    const steps = Array.from(root.querySelectorAll<HTMLElement>("[data-hiw-step]"));
    const screens = Array.from(root.querySelectorAll<HTMLElement>("[data-hiw-screen]"));
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-hiw-dot]"));

    const setActive = (idx: number) => {
      steps.forEach((el, i) => el.classList.toggle("is-active", i === idx));
      screens.forEach((el, i) => el.classList.toggle("is-active", i === idx));
      dots.forEach((el, i) => el.classList.toggle("is-active", i === idx));
    };

    // First screen visible by default.
    setActive(0);

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = Number((entry.target as HTMLElement).dataset.hiwStep);
            setActive(idx);
          }
        });
      },
      // Only the step crossing the vertical centre counts as "active".
      { rootMargin: "-50% 0px -50% 0px", threshold: 0 },
    );
    steps.forEach((el) => io.observe(el));
  }

  // Compact timeline: draw the connector + pop the nodes once it scrolls in.
  function initHowItWorksTimeline() {
    const timeline = document.querySelector<HTMLElement>("[data-hiw-timeline]");
    if (!timeline) return;
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-inview");
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 },
    );
    io.observe(timeline);
  }

  initHowItWorks();
  initHowItWorksTimeline();
  document.addEventListener("astro:page-load", () => {
    initHowItWorks();
    initHowItWorksTimeline();
  });
</script>
