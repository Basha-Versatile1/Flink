---
import StoreBadges from "@/components/ui/StoreBadges.astro";
import LeadForm from "@/components/LeadForm.astro";
import Reveal from "@/components/ui/Reveal.astro";
import PhoneMockup from "@/components/PhoneMockup.astro";
import Icon from "@/components/Icon.astro";
---

<section id="download" class="scroll-mt-24 overflow-hidden border-t border-hairline bg-surface-cyan">
  <div class="container-px py-16 sm:py-20 lg:py-24">
    <!-- Single contained phone showcase (glow + radar pulse + floating chips) -->
    <Reveal>
      <div class="relative mx-auto mb-14 hidden max-w-sm justify-center sm:flex">
        <!-- Aurora glow + radar pulse, centred behind the phone -->
        <div aria-hidden="true" class="animate-aurora pointer-events-none absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/30 blur-3xl"></div>
        <div aria-hidden="true" class="pointer-events-none absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full ring-1 ring-primary/15"></div>
        <div aria-hidden="true" class="animate-pulse-ring pointer-events-none absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full ring-2 ring-primary/25"></div>

        <PhoneMockup class="animate-phone-float relative z-10 !w-[212px] shadow-lift">
          <div class="flex h-full flex-col gap-2 p-3">
            <div class="rounded-lg bg-white p-2.5 shadow-soft">
              <p class="text-[11px] font-semibold text-ink">Pro on the way</p>
              <p class="text-[9px] text-ink-soft">Arriving ~9 min · live tracking</p>
            </div>
            <div class="flex-1 rounded-lg bg-primary/15"></div>
            <div class="grid grid-cols-2 gap-1.5">
              <div class="rounded-lg bg-white/85 py-1.5 text-center text-[9px] font-medium text-ink-soft ring-1 ring-hairline">Chat</div>
              <div class="rounded-lg bg-white/85 py-1.5 text-center text-[9px] font-medium text-ink-soft ring-1 ring-hairline">Call</div>
            </div>
            <div class="rounded-pill bg-primary py-2 text-center text-[11px] font-semibold text-white">Open Flink</div>
          </div>
        </PhoneMockup>

        <!-- Floating glossy chips -->
        <div class="animate-phone-float absolute left-0 top-14 z-20 flex items-center gap-1.5 rounded-pill border border-hairline bg-white/90 px-3 py-1.5 text-xs font-semibold text-ink shadow-lift backdrop-blur">
          <Icon name="shield" size={14} class="text-primary-deep" />Verified pro
        </div>
        <div class="animate-phone-float absolute right-0 top-28 z-20 flex items-center gap-1.5 rounded-pill border border-hairline bg-white/90 px-3 py-1.5 text-xs font-semibold text-ink shadow-lift backdrop-blur [animation-delay:1s]">
          <Icon name="clock" size={14} class="text-primary-deep" />~9 min
        </div>
      </div>
    </Reveal>

    <div class="mx-auto max-w-2xl text-center">
      <Reveal>
        <h2 class="text-[2.25rem] font-bold tracking-tight sm:text-[2.75rem]">
          Trusted house help,<br class="hidden sm:block" />
          <span class="text-primary-deep"> in minutes</span>.
        </h2>
        <p class="mx-auto mt-4 max-w-lg text-lg text-ink-soft">
          Download the Flink app to book a trained professional now — or leave your details and
          we&apos;ll reach out when we&apos;re live near you.
        </p>
        <div class="mt-7 flex justify-center">
          <StoreBadges />
        </div>
      </Reveal>

      <Reveal delay={100}>
        <div class="mt-8 rounded-card border border-hairline bg-white p-6 text-left shadow-soft sm:p-8">
          <h3 class="flex items-center gap-2 text-lg font-semibold text-ink">
            <Icon name="map-pin" size={20} class="text-primary-deep" />
            Request Flink in your area
          </h3>
          <p class="mt-1 text-sm text-ink-soft">Name, phone, and locality — that&apos;s all we need.</p>
          <div class="mt-5">
            <LeadForm />
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</section>
