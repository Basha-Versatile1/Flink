---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import StoreBadges from "@/components/ui/StoreBadges.astro";
import Pill from "@/components/ui/Pill.astro";
import { APP_FEATURES } from "@/data/site";
import type { IconName } from "@/lib/icons";
import { cn } from "@/lib/cn";

// Multi-hue accent tiles for the app feature list.
const TILE_TONES = [
  "bg-surface-cyan text-primary-deep",
  "bg-surface-cyan text-primary-deep",
  "bg-surface-cyan text-primary-deep",
  "bg-surface-cyan text-primary-deep",
  "bg-surface-cyan text-primary-deep",
  "bg-surface-cyan text-primary-deep",
];
---

<Section id="app" tone="cyan">
  <SectionHeading
    eyebrow="In the app"
    title="Everything you need,"
    accent="in one tidy app"
    intro="From frictionless login to live tracking and rewards — the Flink app keeps your home care effortless."
  />

  <div class="mx-auto mt-12 max-w-4xl">
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        APP_FEATURES.map((feature, i) => (
          <Reveal as="li" delay={(i % 3) * 70}>
            <div class="flex h-full gap-3 rounded-card bg-white/70 p-4 ring-1 ring-white/60 backdrop-blur">
              <span class={cn("inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ring-1 ring-black/5", TILE_TONES[i % TILE_TONES.length])}>
                <Icon name={feature.icon as IconName} size={20} />
              </span>
              <div>
                <h3 class="text-sm font-semibold text-ink">{feature.title}</h3>
                <p class="mt-1 text-xs text-ink-soft">{feature.body}</p>
              </div>
            </div>
          </Reveal>
        ))
      }
    </ul>

    <div class="mt-8 flex flex-col items-center gap-3">
      <Pill tone="trust">
        <Icon name="sparkles" size={14} />
        Loyalty points — coming soon
      </Pill>
      <StoreBadges />
    </div>
  </div>
</Section>
