---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { TRUST_PILLARS } from "@/data/site";
---

<Section id="why-flink" tone="cyan">
  <SectionHeading
    eyebrow="Why Flink"
    title="Built on trust,"
    accent="not guesswork"
    intro="We own the whole experience — our people, our training, our standards — so you always know who's at your door."
  />

  <ul class="mx-auto mt-14 grid max-w-5xl gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
    {
      TRUST_PILLARS.map((pillar, i) => (
        <Reveal as="li" delay={(i % 3) * 80} class="border-t-2 border-primary pt-5">
          <h3 class="text-lg font-semibold text-ink">{pillar.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{pillar.body}</p>
        </Reveal>
      ))
    }
  </ul>
</Section>
