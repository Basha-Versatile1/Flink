---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Card from "@/components/ui/Card.astro";
import IconBadge from "@/components/ui/IconBadge.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { TRUST_PILLARS } from "@/data/site";
import type { IconName } from "@/lib/icons";
import type { BadgeTone } from "@/components/ui/IconBadge.astro";

const TONES: BadgeTone[] = ["cyan", "violet", "amber", "emerald", "rose", "blue"];
---

<Section id="why-flink" tone="white">
  <SectionHeading
    eyebrow="Why Flink"
    title="Built on trust,"
    accent="not guesswork"
    intro="We own the whole experience — our people, our training, our standards — so you always know who's at your door."
  />

  <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      TRUST_PILLARS.map((pillar, i) => (
        <Reveal as="li" delay={(i % 3) * 80}>
          <Card hover class="h-full">
            <IconBadge tone={TONES[i % TONES.length]}>
              <Icon name={pillar.icon as IconName} size={24} />
            </IconBadge>
            <h3 class="text-lg font-semibold">{pillar.title}</h3>
            <p class="mt-2 text-sm text-ink-soft">{pillar.body}</p>
          </Card>
        </Reveal>
      ))
    }
  </ul>
</Section>
