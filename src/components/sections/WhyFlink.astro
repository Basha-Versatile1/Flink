---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { TRUST_PILLARS } from "@/data/site";
import type { IconName } from "@/lib/icons";

// Vivid solid icon tiles (gradient + coloured glow + glossy top highlight).
// Literal strings so Tailwind's JIT keeps every class.
const TILES = [
  "bg-gradient-to-br from-orange-500 to-orange-400 shadow-[0_10px_24px_-8px_rgba(249,115,22,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
  "bg-gradient-to-br from-emerald-500 to-emerald-400 shadow-[0_10px_24px_-8px_rgba(5,150,105,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
  "bg-gradient-to-br from-violet-500 to-violet-400 shadow-[0_10px_24px_-8px_rgba(124,58,237,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
  "bg-gradient-to-br from-blue-500 to-blue-400 shadow-[0_10px_24px_-8px_rgba(37,99,235,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
  "bg-gradient-to-br from-amber-500 to-amber-400 shadow-[0_10px_24px_-8px_rgba(217,119,6,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
  "bg-gradient-to-br from-teal-500 to-teal-400 shadow-[0_10px_24px_-8px_rgba(13,148,136,0.7),inset_0_1px_0_0_rgba(255,255,255,0.4)]",
];
---

<Section id="why-flink" tone="dark" class="relative overflow-hidden">
  <!-- Soft cyan glow behind the heading -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-0 h-72 w-[44rem] max-w-full -translate-x-1/2 rounded-full bg-primary/15 blur-[100px]"
  >
  </div>

  <div class="relative">
    <SectionHeading
      eyebrow="Why Flink"
      title="Built on trust,"
      accent="not guesswork"
      intro="We own the whole experience — our people, our training, our standards — so you always know who's at your door."
      onDark
    />

    <ul class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        TRUST_PILLARS.map((pillar, i) => (
          <Reveal as="li" delay={(i % 3) * 80}>
            <div class="flex h-full flex-col rounded-card border border-white/10 bg-white/[0.04] p-6 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.06),0_18px_40px_-24px_rgba(0,0,0,0.85)] backdrop-blur-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06] hover:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.12),0_24px_48px_-20px_rgba(0,0,0,0.95)]">
              <span class={`mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl text-white ${TILES[i % TILES.length]}`}>
                <Icon name={pillar.icon as IconName} size={22} />
              </span>
              <h3 class="text-lg font-semibold text-white">{pillar.title}</h3>
              <p class="mt-2 text-sm text-white/60">{pillar.body}</p>
            </div>
          </Reveal>
        ))
      }
    </ul>
  </div>
</Section>
