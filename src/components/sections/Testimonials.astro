---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import StarRating from "@/components/ui/StarRating.astro";
import Card from "@/components/ui/Card.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { TESTIMONIALS, RATING_SUMMARY } from "@/data/testimonials";

/**
 * Testimonials grid. Content is SAMPLE/placeholder (see data/testimonials.ts).
 * Aggregate rating + service-level reviews only (no individual-staff content).
 */
---

<Section id="reviews" tone="slate">
  <SectionHeading
    eyebrow="Reviews"
    title="What early customers"
    accent="are saying"
    intro="Aggregate service ratings from real bookings. (Sample reviews shown during launch.)"
  />

  <!-- Aggregate summary -->
  <div class="mx-auto mt-8 flex max-w-sm items-center justify-center gap-4 rounded-card border border-hairline bg-white p-5 shadow-soft">
    <span class="text-4xl font-bold text-ink">{RATING_SUMMARY.average}</span>
    <div>
      <StarRating rating={RATING_SUMMARY.average} />
      <p class="mt-1 text-sm text-ink-soft">Based on {RATING_SUMMARY.count} service reviews</p>
    </div>
  </div>

  <!-- Grid -->
  <ul class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      TESTIMONIALS.map((t, i) => (
        <Reveal as="li" delay={(i % 3) * 70}>
          <Card class="flex h-full flex-col">
            <StarRating rating={t.rating} size={16} />
            <blockquote class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">
              “{t.quote}”
            </blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary text-sm font-semibold text-white">
                {t.name.charAt(0)}
              </span>
              <span class="text-sm">
                <span class="block font-semibold text-ink">{t.name}</span>
                <span class="text-ink-soft">{t.locality}</span>
              </span>
            </figcaption>
          </Card>
        </Reveal>
      ))
    }
  </ul>
</Section>
