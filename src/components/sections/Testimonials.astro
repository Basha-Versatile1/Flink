---
import Section from "@/components/ui/Section.astro";
import { TESTIMONIALS } from "@/data/testimonials";

/**
 * Reviews — "success stories" style cards. Content is SAMPLE/placeholder
 * (see data/testimonials.ts): aggregate service-level feedback only, no
 * individual-staff content. Replace with consented reviews before launch.
 */

// Per-card accent — the quote badge and the initials avatar share the colour.
// Literal class strings so Tailwind's JIT keeps each gradient.
const ACCENTS = [
  "bg-primary",
  "bg-primary",
  "bg-primary",
  "bg-primary",
  "bg-primary",
];

const initials = (name: string) =>
  name
    .split(" ")
    .map((p) => p.charAt(0))
    .join("")
    .slice(0, 2)
    .toUpperCase();
---

<Section id="reviews" tone="white" class="relative overflow-hidden">
  <!-- Soft corner washes -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -left-24 -top-24 h-80 w-80 rounded-full bg-primary/20 blur-[110px]"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-24 -top-16 h-80 w-80 rounded-full bg-primary/20 blur-[110px]"
  >
  </div>

  <div class="relative">
    <!-- Heading -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="mb-4 inline-flex items-center gap-2 rounded-pill border border-primary/30 bg-surface-cyan px-4 py-1.5 text-base font-bold uppercase tracking-wide text-primary-deep">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="m12 2 2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 7.1-1.01L12 2Z"></path>
        </svg>
        Reviews
      </span>
      <h2 class="text-[2.25rem] font-bold tracking-tight text-ink sm:text-[2.75rem]">
        What early customers <span class="text-primary-deep">are saying</span>
      </h2>
      <p class="mt-4 text-lg text-ink-soft">
        Real experiences from early Flink bookings. (Sample reviews shown during launch.)
      </p>
    </div>

    <!-- Cards — single-row auto-scrolling marquee (pauses on hover) -->
    <div class="marquee-mask relative mt-14 overflow-hidden">
      <ul class="animate-marquee flex w-max items-stretch gap-6 py-10">
        {
          [...TESTIMONIALS, ...TESTIMONIALS].map((t, i) => (
            <li
              class="w-[340px] shrink-0"
              aria-hidden={i >= TESTIMONIALS.length ? "true" : undefined}
            >
              <figure class="relative h-full rounded-[1.75rem] bg-white p-7 pt-9 shadow-[0_24px_60px_-30px_rgba(15,23,42,0.35)] ring-1 ring-hairline/70 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_30px_70px_-28px_rgba(15,23,42,0.45)]">
                <span
                  class={`absolute -top-5 left-7 inline-flex h-12 w-12 items-center justify-center rounded-full text-white ${ACCENTS[i % ACCENTS.length]}`}
                >
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M7.5 6C5 6 3 8 3 10.5V18h6.5v-6.5H6.2C6.6 9.6 7.9 8.4 9.5 8.4V6H7.5Zm9 0C14 6 12 8 12 10.5V18h6.5v-6.5h-3.3c.4-1.9 1.7-3.1 3.3-3.1V6h-2Z" />
                  </svg>
                </span>
                <blockquote class="text-base italic leading-relaxed text-ink-soft">
                  “{t.quote}”
                </blockquote>
                <figcaption class="mt-7 flex items-center gap-3">
                  <span
                    class={`inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full text-sm font-bold text-white ${ACCENTS[i % ACCENTS.length]}`}
                  >
                    {initials(t.name)}
                  </span>
                  <span>
                    <span class="block font-semibold text-ink">{t.name}</span>
                    <span class="text-sm text-ink-soft">{t.locality}</span>
                  </span>
                </figcaption>
              </figure>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</Section>
