---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import Button from "@/components/ui/Button.astro";
import Pill from "@/components/ui/Pill.astro";

// Numbers are placeholders ([₹XX/hr], [₹XX/task]) until the client finalises pricing (§2).
const PRICING_POINTS = [
  "Pay by the hour or per task — your choice",
  "The exact rate is shown before you confirm",
  "No subscriptions, no hidden fees, no lock-in",
  "Wallet, coupons & referral credit in the app",
];
---

<Section id="pricing" tone="white">
  <SectionHeading
    eyebrow="Pricing"
    title="Transparent pricing,"
    accent="every single time"
    intro="Two simple ways to pay — and you always see the number first."
  />

  <div class="mx-auto mt-12 grid max-w-4xl gap-5 md:grid-cols-2">
    <Reveal>
      <div class="flex h-full flex-col rounded-card border border-hairline bg-white p-7 shadow-soft">
        <span class="text-sm font-semibold uppercase tracking-wide text-primary-deep">Hourly</span>
        <p class="mt-3 text-4xl font-bold text-ink">
          {/* TODO: final pricing */}[₹XX]<span class="text-base font-medium text-ink-soft">/hr</span>
        </p>
        <p class="mt-2 text-sm text-ink-soft">
          Great for bigger jobs or when you want the pro to keep going until it&apos;s done.
        </p>
        <Button href="#download" size="lg" class="mt-6">Book hourly</Button>
      </div>
    </Reveal>

    <Reveal delay={80}>
      <div class="relative flex h-full flex-col rounded-card bg-primary p-7 shadow-soft">
        <span class="absolute right-5 top-5">
          <Pill tone="neutral" class="bg-white/90 text-primary-deep ring-white/40">Popular</Pill>
        </span>
        <span class="text-sm font-semibold uppercase tracking-wide text-ink/70">Per task</span>
        <p class="mt-3 text-4xl font-bold text-ink">
          {/* TODO: final pricing */}[₹XX]<span class="text-base font-medium text-ink/70">/task</span>
        </p>
        <p class="mt-2 text-sm text-ink/80">
          Fixed price for a single, well-defined job — like one bathroom or the dishes.
        </p>
        <Button href="#download" variant="secondary" size="lg" class="mt-6">Book a task</Button>
      </div>
    </Reveal>
  </div>

  <div class="mx-auto mt-8 max-w-4xl">
    <ul class="grid gap-3 sm:grid-cols-2">
      {
        PRICING_POINTS.map((point) => (
          <li class="flex items-start gap-2.5 text-sm text-ink-soft">
            <Icon name="check" size={18} class="mt-0.5 shrink-0 text-primary" />
            {point}
          </li>
        ))
      }
    </ul>

    <div class="mt-6 flex flex-col items-start justify-between gap-4 rounded-card border border-hairline bg-white p-5 shadow-soft sm:flex-row sm:items-center">
      <p class="text-sm font-medium text-ink">
        {/* TODO: confirm new-user / referral offer */}
        ✨ New to Flink? Your first booking and referrals come with app credit.
      </p>
      <Button href="#download" size="md">Get the app</Button>
    </div>
  </div>
</Section>
