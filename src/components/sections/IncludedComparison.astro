---
import Section from "@/components/ui/Section.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { INCLUDED, NOT_INCLUDED } from "@/data/site";
---

<Section id="whats-included" tone="dark">
  <SectionHeading
    eyebrow="What to expect"
    title="What's included —"
    accent="and what's not"
    intro="We keep the scope clear so there are no surprises when your professional arrives."
    onDark
  />

  <div class="mx-auto mt-12 grid max-w-4xl gap-5 md:grid-cols-2">
    <Reveal>
      <div class="h-full rounded-card bg-surface-cyan p-6 ring-1 ring-primary/15">
        <h3 class="flex items-center gap-2 text-lg text-ink">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-trust text-white">
            <Icon name="check" size={16} />
          </span>
          Included in a visit
        </h3>
        <ul class="mt-5 space-y-3">
          {
            INCLUDED.map((item) => (
              <li class="flex items-start gap-3 text-sm text-ink-soft">
                <Icon name="check" size={18} class="mt-0.5 shrink-0 text-trust" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </Reveal>

    <Reveal delay={80}>
      <div class="h-full rounded-card bg-surface-slate p-6 ring-1 ring-hairline">
        <h3 class="flex items-center gap-2 text-lg text-ink">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink-soft/80 text-white">
            <Icon name="x" size={16} />
          </span>
          Not included
        </h3>
        <ul class="mt-5 space-y-3">
          {
            NOT_INCLUDED.map((item) => (
              <li class="flex items-start gap-3 text-sm text-ink-soft">
                <Icon name="x" size={18} class="mt-0.5 shrink-0 text-ink-soft/60" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </Reveal>
  </div>
</Section>
