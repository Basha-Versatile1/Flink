---
import Section from "@/components/ui/Section.astro";
import Pill from "@/components/ui/Pill.astro";
import { COMPANY } from "@/lib/config";

/**
 * Shared shell for legal stub pages. Content is TODO until the client supplies
 * finalised, lawyer-reviewed policy text.
 */
interface Props {
  title: string;
  intro: string;
}
const { title, intro } = Astro.props;
---

<Section tone="white">
  <div class="mx-auto max-w-3xl">
    <Pill tone="neutral">Draft — pending final copy</Pill>
    <h1 class="mt-4 text-3xl sm:text-4xl">{title}</h1>
    <p class="mt-3 text-lg text-ink-soft">{intro}</p>

    <!-- TODO: replace placeholder body with finalised, legally-reviewed content. -->
    <div class="prose mt-8 max-w-none space-y-5 text-ink-soft [&_h2]:mt-8 [&_h2]:text-xl [&_h2]:text-ink">
      <slot />
    </div>

    <div class="mt-12 rounded-card bg-surface-slate p-5 text-sm text-ink-soft ring-1 ring-hairline">
      <strong class="text-ink">Placeholder notice:</strong> This page is a stub. Final terms will be
      published by {COMPANY.legalName} before launch. For questions, contact
      <a href={`mailto:${COMPANY.supportEmail}`} class="font-medium text-primary-deep underline">{COMPANY.supportEmail}</a>.
    </div>
  </div>
</Section>
