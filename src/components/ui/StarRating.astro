---
import Icon from "@/components/Icon.astro";
import { cn } from "@/lib/cn";

interface Props {
  rating: number;
  size?: number;
  class?: string;
}

const { rating, size = 18, class: className } = Astro.props;
const rounded = Math.round(rating);
const stars = Array.from({ length: 5 }, (_, i) => i < rounded);
---

<span
  class={cn("inline-flex items-center gap-0.5 text-amber-400", className)}
  role="img"
  aria-label={`${rating} out of 5 stars`}
>
  {
    stars.map((filled) => (
      <Icon
        name={filled ? "star-filled" : "star"}
        size={size}
        class={filled ? "text-amber-400" : "text-hairline"}
      />
    ))
  }
</span>
