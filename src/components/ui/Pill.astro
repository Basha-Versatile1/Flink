---
import { cn } from "@/lib/cn";

interface Props {
  tone?: "cyan" | "trust" | "neutral";
  class?: string;
}

const { tone = "cyan", class: className } = Astro.props;

const tones = {
  cyan: "bg-surface-cyan text-primary-deep ring-1 ring-primary/20",
  trust: "bg-trust/10 text-trust ring-1 ring-trust/20",
  neutral: "bg-surface-slate text-ink-soft ring-1 ring-hairline",
} as const;
---

<span
  class={cn(
    "inline-flex items-center gap-1.5 rounded-pill px-3 py-1 text-sm font-medium",
    tones[tone],
    className,
  )}
>
  <slot />
</span>
