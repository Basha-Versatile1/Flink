---
import { cn } from "@/lib/cn";

/**
 * Icon badge used at the top of feature/service cards. `tone` adds a secondary
 * accent colour (vastyn-style multi-hue); cyan is the default brand tone.
 * `onDark` switches to vivid translucent tiles for near-black sections.
 * Class strings are literal so Tailwind's JIT keeps them.
 */
export type BadgeTone = "cyan" | "violet" | "amber" | "emerald" | "rose" | "blue";

interface Props {
  tone?: BadgeTone;
  onDark?: boolean;
  class?: string;
}
const { tone = "cyan", onDark = false, class: className } = Astro.props;

const light: Record<BadgeTone, string> = {
  cyan: "bg-surface-cyan text-primary-deep ring-primary/15",
  violet: "bg-surface-cyan text-primary-deep ring-primary/15",
  amber: "bg-surface-cyan text-primary-deep ring-primary/15",
  emerald: "bg-surface-cyan text-primary-deep ring-primary/15",
  rose: "bg-surface-cyan text-primary-deep ring-primary/15",
  blue: "bg-surface-cyan text-primary-deep ring-primary/15",
};

const dark: Record<BadgeTone, string> = {
  cyan: "bg-primary/15 text-primary-light ring-primary/25",
  violet: "bg-primary/15 text-primary-light ring-primary/25",
  amber: "bg-primary/15 text-primary-light ring-primary/25",
  emerald: "bg-primary/15 text-primary-light ring-primary/25",
  rose: "bg-primary/15 text-primary-light ring-primary/25",
  blue: "bg-primary/15 text-primary-light ring-primary/25",
};
---

<span
  class={cn(
    // Glossy tile: inset top highlight + soft drop shadow for a convex sheen.
    "mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl ring-1 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.55),0_6px_14px_-6px_rgba(15,23,42,0.2)]",
    (onDark ? dark : light)[tone],
    className,
  )}
>
  <slot />
</span>
