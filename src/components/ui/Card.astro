---
import { cn } from "@/lib/cn";

interface Props {
  class?: string;
  hover?: boolean;
  as?: "div" | "article" | "li";
}

const { class: className, hover = false, as: Tag = "div" } = Astro.props;
---

<Tag
  class={cn(
    // Flat white card.
    "rounded-card bg-white p-6 ring-1 ring-hairline/70 shadow-soft",
    hover &&
      "transition-all duration-200 hover:-translate-y-0.5 hover:ring-primary/40 hover:shadow-[0_18px_40px_-16px_rgba(15,23,42,0.22),inset_0_1px_0_0_rgba(255,255,255,1)]",
    className,
  )}
>
  <slot />
</Tag>
