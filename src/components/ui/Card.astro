---
import { cn } from "@/lib/cn";

interface Props {
  class?: string;
  hover?: boolean;
  as?: "div" | "article" | "li";
}

const { class: className, hover = false, as: Tag = "div" } = Astro.props;
---

<Tag
  class={cn(
    "rounded-card bg-white p-6 shadow-soft ring-1 ring-hairline/70",
    hover &&
      "transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-lift hover:ring-primary/40",
    className,
  )}
>
  <slot />
</Tag>
