---
import { cn } from "@/lib/cn";

/**
 * Scroll-reveal wrapper. Adds the `.reveal` class; a single global
 * IntersectionObserver (in Layout.astro) toggles `.is-visible`. Fully disabled
 * under prefers-reduced-motion via CSS. Zero per-instance JavaScript.
 */
interface Props {
  class?: string;
  delay?: number;
  as?: "div" | "li" | "article";
}

const { class: className, delay = 0, as: Tag = "div" } = Astro.props;
---

<Tag class={cn("reveal", className)} style={delay ? `transition-delay:${delay}ms` : undefined}>
  <slot />
</Tag>
