---
import { cn } from "@/lib/cn";

/**
 * Placeholder phone mockup frame. Wrap any content to fake an app screen.
 * TODO: replace inner content with real app screenshots when available.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div
  class={cn(
    "group relative mx-auto aspect-[9/19] w-[240px] rounded-[2.2rem] border-[6px] border-ink bg-white shadow-lift",
    className,
  )}
>
  <div class="absolute left-1/2 top-2 z-10 h-5 w-24 -translate-x-1/2 rounded-full bg-ink"></div>
  <div class="relative h-full w-full overflow-hidden rounded-[1.7rem] bg-surface-cyan">
    <slot />

    {/* Static glass sheen */}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 rounded-[1.7rem] bg-gradient-to-br from-white/30 via-white/5 to-transparent"
    >
    </div>
    {/* Soft inner edge highlight */}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 rounded-[1.7rem] shadow-[inset_0_1px_2px_0_rgba(255,255,255,0.6),inset_0_-12px_24px_-12px_rgba(15,23,42,0.25)]"
    >
    </div>
    {/* Light shine that sweeps across on hover */}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 left-0 w-1/3 -translate-x-[200%] -skew-x-12 bg-gradient-to-r from-transparent via-white/55 to-transparent transition-transform duration-700 ease-out motion-safe:group-hover:translate-x-[400%]"
    >
    </div>
  </div>
</div>
