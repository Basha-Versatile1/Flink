---
/**
 * Ambient site background — soft, brand-tinted glows over a faint dot grid.
 * Fixed to the viewport and sits behind all content (pointer-events-none, -z-10).
 * Visible on any page/section with a transparent background; opaque sections
 * (e.g. the homepage) simply cover it, so there's no visual regression there.
 */
---

<div aria-hidden="true" class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
  <!-- Base wash: flat light cyan tint -->
  <div class="absolute inset-0 bg-surface-cyan"></div>

  <!-- Soft colour glows -->
  <div class="absolute -right-32 -top-40 h-[34rem] w-[34rem] rounded-full bg-primary/40 blur-3xl"></div>
  <div class="absolute -left-40 top-1/4 h-[30rem] w-[30rem] rounded-full bg-primary/20 blur-3xl"></div>
  <div class="absolute -bottom-32 right-1/4 h-[30rem] w-[30rem] rounded-full bg-primary/15 blur-3xl"></div>
  <div class="absolute bottom-1/4 -left-24 h-[24rem] w-[24rem] rounded-full bg-primary/15 blur-3xl"></div>

  <!-- Dot grid texture, fading out toward the edges -->
  <div
    class="absolute inset-0 opacity-70 [mask-image:radial-gradient(ellipse_at_center,#000_25%,transparent_80%)]"
    style="background-image: radial-gradient(rgba(15,23,42,0.10) 1px, transparent 1.6px); background-size: 24px 24px;"
  >
  </div>
</div>
